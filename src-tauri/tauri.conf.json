{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Theorem",
  "version": "0.1.0-beta.1",
  "identifier": "work.fundamentals.theorem",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Theorem",
        "width": 1440,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": false,
        "transparent": false,
        "center": true,
        "maximized": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: asset: http://asset.localhost https: http:; connect-src 'self' ws: data: blob: asset: http://asset.localhost https: http:; worker-src 'self' blob: asset: http://asset.localhost",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/**",
          "$APPCONFIG/**",
          "$APPLOCALDATA/**",
          "$RESOURCE/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Education",
    "publisher": "Fundamentals",
    "homepage": "https://github.com/sapienskid/theorem",
    "shortDescription": "Local-first reader for PDFs, EPUBs, and RSS with markdown export.",
    "longDescription": "Theorem is a free, open-source, local-first reading app for PDFs, EPUBs and RSS. Highlight and annotate anything, capture vocabulary, and sync notes to local Markdown files for Obsidian or Logseq. No cloud account, no subscription, no vendor lock-in.",
    "copyright": "Copyright (c) 2026 Fundamentals",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "name": "EPUB ebook",
        "description": "Electronic publication",
        "ext": [
          "epub"
        ],
        "mimeType": "application/epub+zip",
        "role": "Viewer"
      },
      {
        "name": "MOBI ebook",
        "description": "Mobipocket ebook",
        "ext": [
          "mobi"
        ],
        "mimeType": "application/x-mobipocket-ebook",
        "role": "Viewer"
      },
      {
        "name": "AZW ebook",
        "description": "Kindle ebook",
        "ext": [
          "azw"
        ],
        "mimeType": "application/vnd.amazon.ebook",
        "role": "Viewer"
      },
      {
        "name": "AZW3 ebook",
        "description": "Kindle Format 8 ebook",
        "ext": [
          "azw3"
        ],
        "mimeType": "application/vnd.amazon.mobi8-ebook",
        "role": "Viewer"
      },
      {
        "name": "FB2 ebook",
        "description": "FictionBook ebook",
        "ext": [
          "fb2"
        ],
        "mimeType": "application/x-fictionbook+xml",
        "role": "Viewer"
      },
      {
        "name": "CBZ comic archive",
        "description": "Comic book ZIP archive",
        "ext": [
          "cbz"
        ],
        "mimeType": "application/vnd.comicbook+zip",
        "role": "Viewer"
      },
      {
        "name": "PDF document",
        "description": "Portable document format",
        "ext": [
          "pdf"
        ],
        "mimeType": "application/pdf",
        "role": "Viewer"
      }
    ],
    "resources": {
      "../node_modules/pdfjs-dist/build/pdf.worker.mjs": "pdfjs/build/pdf.worker.mjs",
      "../node_modules/pdfjs-dist/build/pdf.worker.min.mjs": "pdfjs/build/pdf.worker.min.mjs",
      "../node_modules/pdfjs-dist/cmaps/": "pdfjs/cmaps/",
      "../node_modules/pdfjs-dist/standard_fonts/": "pdfjs/standard_fonts/"
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      },
      "deb": {
        "section": "utils",
        "files": {}
      },
      "rpm": {
        "epoch": 0,
        "release": "1"
      }
    },
    "android": {
      "minSdkVersion": 24
    }
  }
}
