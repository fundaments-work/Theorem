{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Theorem",
  "version": "0.1.0",
  "identifier": "work.fundamentals.theorem",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Theorem",
        "width": 1440,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": false,
        "transparent": false,
        "center": true,
        "maximized": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: asset: http://asset.localhost https: http:; connect-src 'self' ws: data: blob: asset: http://asset.localhost https: http:; worker-src 'self' blob: asset: http://asset.localhost",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/**",
          "$APPCONFIG/**",
          "$APPLOCALDATA/**",
          "$RESOURCE/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Education",
    "publisher": "Fundamentals",
    "homepage": "https://github.com/sapienskid/hodor",
    "shortDescription": "Local-first reader for ebooks, PDFs, and RSS feeds.",
    "longDescription": "Theorem is a local-first reading workspace for EPUB, MOBI, AZW, AZW3, FB2, CBZ, and PDF books plus RSS articles. Organize your library, annotate across formats, capture vocabulary, and export notes to markdown.",
    "copyright": "Copyright (c) 2026 Fundamentals",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "name": "EPUB ebook",
        "description": "Electronic publication",
        "ext": [
          "epub"
        ],
        "mimeType": "application/epub+zip",
        "role": "Viewer"
      },
      {
        "name": "MOBI ebook",
        "description": "Mobipocket ebook",
        "ext": [
          "mobi"
        ],
        "mimeType": "application/x-mobipocket-ebook",
        "role": "Viewer"
      },
      {
        "name": "AZW ebook",
        "description": "Kindle ebook",
        "ext": [
          "azw"
        ],
        "mimeType": "application/vnd.amazon.ebook",
        "role": "Viewer"
      },
      {
        "name": "AZW3 ebook",
        "description": "Kindle Format 8 ebook",
        "ext": [
          "azw3"
        ],
        "mimeType": "application/vnd.amazon.mobi8-ebook",
        "role": "Viewer"
      },
      {
        "name": "FB2 ebook",
        "description": "FictionBook ebook",
        "ext": [
          "fb2"
        ],
        "mimeType": "application/x-fictionbook+xml",
        "role": "Viewer"
      },
      {
        "name": "CBZ comic archive",
        "description": "Comic book ZIP archive",
        "ext": [
          "cbz"
        ],
        "mimeType": "application/vnd.comicbook+zip",
        "role": "Viewer"
      },
      {
        "name": "PDF document",
        "description": "Portable document format",
        "ext": [
          "pdf"
        ],
        "mimeType": "application/pdf",
        "role": "Viewer"
      }
    ],
    "resources": {
      "../node_modules/pdfjs-dist/build/pdf.worker.mjs": "pdfjs/build/pdf.worker.mjs",
      "../node_modules/pdfjs-dist/build/pdf.worker.min.mjs": "pdfjs/build/pdf.worker.min.mjs",
      "../node_modules/pdfjs-dist/cmaps/": "pdfjs/cmaps/",
      "../node_modules/pdfjs-dist/standard_fonts/": "pdfjs/standard_fonts/"
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      },
      "deb": {
        "section": "utils",
        "files": {}
      },
      "rpm": {
        "epoch": 0,
        "release": "1"
      }
    },
    "android": {
      "minSdkVersion": 24
    }
  }
}
