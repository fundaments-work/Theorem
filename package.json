{
    "name": "lionreader-monorepo",
    "private": true,
    "workspaces": [
        "apps/*",
        "packages/*",
        "packages/features/*"
    ],
    "scripts": {
        "dev": "npm run dev --workspace=@lionreader/web",
        "build": "npm run build --workspaces",
        "test": "npm run test --workspaces",
        "tauri": "npm run tauri --workspace=@lionreader/web"
    },
    "devDependencies": {
        "typescript": "^5.0.0",
        "@types/node": "^22.0.0",
        "vite": "^7.0.0"
    }
}