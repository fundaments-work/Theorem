{
    "compilerOptions": {
        "target": "ES2020",
        "useDefineForClassFields": true,
        "lib": [
            "ES2020",
            "DOM",
            "DOM.Iterable"
        ],
        "module": "ESNext",
        "skipLibCheck": true,
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "noEmit": true,
        "jsx": "react-jsx",
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "./src/*"
            ],
            "@theorem/core": [
                "../../packages/core/src"
            ],
            "@theorem/ui": [
                "../../packages/ui/src"
            ],
            "@theorem/feature-reader": [
                "../../packages/features/reader/src"
            ],
            "@foliate-js/*": [
                "../../packages/features/reader/foliate-js/*"
            ],
            "@theorem/feature-library": [
                "../../packages/features/library/src"
            ],
            "@theorem/feature-settings": [
                "../../packages/features/settings/src"
            ],
            "@theorem/feature-statistics": [
                "../../packages/features/statistics/src"
            ],
            "@theorem/feature-vocabulary": [
                "../../packages/features/vocabulary/src"
            ],
            "@theorem/feature-learning": [
                "../../packages/features/learning/src"
            ]
        },
        "strict": true,
        "noUnusedLocals": false,
        "noUnusedParameters": false,
        "noFallthroughCasesInSwitch": true,
        "allowJs": true,
        "checkJs": false
    },
    "include": [
        "src"
    ],
    "references": [
        {
            "path": "./tsconfig.node.json"
        }
    ]
}